{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Syncora",
  "version": "0.1.0",
  "identifier": "app.syncora.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:release"
  },
  "app": {
    "windows": [
      {
        "title": "Syncora",
        "width": 800,
        "height": 800,
        "minWidth": 800,
        "minHeight": 800,
        "maxWidth": 800,
        "maxHeight": 800,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../backend/dist/": "backend/"
    },
    "windows": {
      "nsis": {
        "template": "installer/syncora-installer.nsi",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "headerImage": "installer/nsis-header.bmp",
        "sidebarImage": "installer/nsis-sidebar.bmp",
        "uninstallerHeaderImage": "installer/nsis-header.bmp",
        "installMode": "currentUser",
        "languages": [
          "PortugueseBR"
        ],
        "displayLanguageSelector": false,
        "compression": "lzma"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
